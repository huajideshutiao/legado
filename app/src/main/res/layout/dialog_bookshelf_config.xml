<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:id="@+id/ll_group_style"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:padding="6dp"
                android:text="@string/group_style"
                android:textColor="@color/primaryText" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/sp_group_style"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:entries="@array/group_style"
                tools:ignore="TouchTargetSizeCheck" />

        </LinearLayout>

        <io.legado.app.ui.widget.ThemeSwitch
            android:id="@+id/sw_show_unread"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="@string/show_unread"
            tools:ignore="TouchTargetSizeCheck" />


        <io.legado.app.ui.widget.ThemeSwitch
            android:id="@+id/sw_show_group_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="@string/bookshelf_show_group_count"
            tools:ignore="TouchTargetSizeCheck" />

        <io.legado.app.ui.widget.ThemeSwitch
            android:id="@+id/sw_fixed_width_mode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="@string/fixed_width_mode"
            tools:ignore="TouchTargetSizeCheck" />

        <io.legado.app.ui.widget.text.AccentTextView
            android:id="@+id/tv_layout_title"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:text="@string/view"
            android:textSize="16sp" />

        <LinearLayout
            android:id="@+id/ll_column_count"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="6dp">

            <TextView
                android:id="@+id/tv_column_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/column_count"
                android:textColor="@color/primaryText" />

            <io.legado.app.ui.widget.seekbar.ThemeSeekBar
                android:id="@+id/sb_column_count"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="6"
                android:progress="0"
                tools:ignore="TouchTargetSizeCheck" />

            <TextView
                android:id="@+id/tv_column_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minWidth="40dp"
                android:textColor="@color/primaryText"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="列表" />

        </LinearLayout>

        <io.legado.app.ui.widget.ThemeSwitch
            android:id="@+id/sw_show_kind"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="@string/bookshelf_list_show_kind"
            tools:ignore="TouchTargetSizeCheck" />

        <io.legado.app.ui.widget.ThemeSwitch
            android:id="@+id/sw_show_intro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="@string/bookshelf_list_show_intro"
            tools:ignore="TouchTargetSizeCheck" />

        <LinearLayout
            android:id="@+id/ll_intro_lines"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            tools:ignore="RtlSymmetry">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/bookshelf_list_intro_lines"
                android:textColor="@color/primaryText" />

            <TextView
                android:id="@+id/tv_intro_lines_minus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="-"
                android:textColor="@color/primaryText"
                android:textSize="18sp"
                tools:ignore="HardcodedText,TouchTargetSizeCheck" />

            <TextView
                android:id="@+id/tv_intro_lines_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:minWidth="32dp"
                android:textColor="@color/primaryText"
                android:textSize="16sp"
                tools:text="2" />

            <TextView
                android:id="@+id/tv_intro_lines_plus"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/primaryText"
                android:textSize="18sp"
                tools:ignore="HardcodedText,TouchTargetSizeCheck" />

        </LinearLayout>

        <io.legado.app.ui.widget.ThemeSwitch
            android:id="@+id/sw_show_last_update_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="6dp"
            android:text="@string/show_last_update_time"
            tools:ignore="TouchTargetSizeCheck" />

        <LinearLayout
            android:id="@+id/ll_fixed_width"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/grid_width_dp" />

            <EditText
                android:id="@+id/et_grid_width"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:inputType="number"
                android:text="100"
                android:textAlignment="center"
                tools:ignore="HardcodedText,TouchTargetSizeCheck,Autofill" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" dp" />

        </LinearLayout>

        <io.legado.app.ui.widget.text.AccentTextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="6dp"
            android:text="@string/sort"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/rg_sort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <io.legado.app.ui.widget.checkbox.ThemeRadioButton
                android:id="@+id/rb_sort_0"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf_px_0"
                tools:ignore="TouchTargetSizeCheck" />

            <io.legado.app.ui.widget.checkbox.ThemeRadioButton
                android:id="@+id/rb_sort_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf_px_1"
                tools:ignore="TouchTargetSizeCheck" />

            <io.legado.app.ui.widget.checkbox.ThemeRadioButton
                android:id="@+id/rb_sort_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf_px_2"
                tools:ignore="TouchTargetSizeCheck" />

            <io.legado.app.ui.widget.checkbox.ThemeRadioButton
                android:id="@+id/rb_sort_3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf_px_3"
                tools:ignore="TouchTargetSizeCheck" />

            <io.legado.app.ui.widget.checkbox.ThemeRadioButton
                android:id="@+id/rb_sort_4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf_px_4"
                tools:ignore="TouchTargetSizeCheck" />

            <io.legado.app.ui.widget.checkbox.ThemeRadioButton
                android:id="@+id/rb_sort_5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bookshelf_px_5"
                tools:ignore="TouchTargetSizeCheck" />

        </RadioGroup>

    </LinearLayout>

</ScrollView>
