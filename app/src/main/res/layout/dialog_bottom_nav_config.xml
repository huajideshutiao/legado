<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <io.legado.app.lib.theme.view.ThemeSwitch
        android:id="@+id/sw_show_discovery"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/show_discovery"
        android:textColor="@color/primaryText"
        android:textSize="15sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/bottom_bar_height"
            android:textColor="@color/primaryText"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_height_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="48dp"
            android:textAlignment="textEnd"
            android:textColor="@color/primaryText"
            android:textSize="15sp"
            tools:text="50dp" />

    </LinearLayout>

    <io.legado.app.lib.theme.view.ThemeSeekBar
        android:id="@+id/sb_height"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="44"
        tools:ignore="TouchTargetSizeCheck" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/bottom_bar_icon_size"
            android:textColor="@color/primaryText"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tv_icon_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="48dp"
            android:textAlignment="textEnd"
            android:textColor="@color/primaryText"
            android:textSize="15sp"
            tools:text="24dp" />

    </LinearLayout>

    <io.legado.app.lib.theme.view.ThemeSeekBar
        android:id="@+id/sb_icon"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="18"
        tools:ignore="TouchTargetSizeCheck" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/bottom_bar_label_mode"
        android:textColor="@color/primaryText"
        android:textSize="15sp" />

    <RadioGroup
        android:id="@+id/rg_label_mode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <io.legado.app.lib.theme.view.ThemeRadioButton
            android:id="@+id/rb_label_unlabeled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bottom_bar_label_unlabeled"
            tools:ignore="TouchTargetSizeCheck" />

        <io.legado.app.lib.theme.view.ThemeRadioButton
            android:id="@+id/rb_label_labeled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bottom_bar_label_labeled"
            tools:ignore="TouchTargetSizeCheck" />

        <io.legado.app.lib.theme.view.ThemeRadioButton
            android:id="@+id/rb_label_selected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bottom_bar_label_selected"
            tools:ignore="TouchTargetSizeCheck" />

        <io.legado.app.lib.theme.view.ThemeRadioButton
            android:id="@+id/rb_label_auto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/bottom_bar_label_auto"
            tools:ignore="TouchTargetSizeCheck" />

    </RadioGroup>

</LinearLayout>
