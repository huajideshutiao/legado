<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_item_focused_on_tv"
    android:focusable="true"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingTop="4dp">

    <LinearLayout
        android:id="@+id/ll_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_find_book_group"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/primaryText"
            tools:text="起点中文" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/rotate_loading"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:layout_marginRight="4dp"
            android:visibility="gone"
            app:indicatorSize="20dp"
            app:trackThickness="1dp"
            tools:ignore="RtlHardcoded" />

        <ImageView
            android:id="@+id/iv_status"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_arrow_right"
            app:tint="@color/secondaryText"
            tools:ignore="ContentDescription" />

    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:paddingTop="4dp">

        <GridLayout
            android:id="@+id/flexbox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:clipToPadding="false"
            android:columnCount="12"
            android:orientation="horizontal"
            android:overScrollMode="never"
            android:visibility="gone">

            <!--
              列宽锚定：占满 12 列、0 高度的占位 Space。
              GridLayout 的列宽是全局求解的，必须有一行宣告满 12 列权重，
              其它行 cols 之和不足 12 时才会按比例占宽并保留右侧留白，
              否则同行所有 cell 会被均分。
            -->
            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_row="0"
                android:layout_rowWeight="0"
                android:layout_column="0"
                android:layout_columnSpan="12"
                android:layout_columnWeight="12" />

        </GridLayout>

    </FrameLayout>

</LinearLayout>